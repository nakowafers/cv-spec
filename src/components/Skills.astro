---
import type { SkillCategory } from "../types";

interface Props {
  skills: SkillCategory[];
}

const { skills } = Astro.props;
---

<section class="card">
  <h2 class="section-title">Skills</h2>
  <div class="skills-grid">
    {
      skills.map((group) => (
        <div class="skill-group">
          <h3 class="skill-category">{group.category}</h3>
          <div class="skill-tags">
            {group.items.map((skill) => <span class="tag">{skill}</span>)}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .skills-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .skill-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .skill-category {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    display: inline-block;
    font-size: 0.8125rem;
    padding: 0.25rem 0.6rem;
    background: var(--color-accent-light);
    color: var(--color-accent);
    border-radius: 4px;
    font-weight: 500;
    line-height: 1.3;
  }

  @media print {
    .skill-group {
      flex-direction: row;
      align-items: baseline;
      gap: 0.5rem;
    }

    .tag {
      font-size: 8pt;
      padding: 0.1rem 0.35rem;
    }
  }
</style>
