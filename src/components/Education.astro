---
import type { Education } from "../types";

interface Props {
  education: Education[];
}

const { education } = Astro.props;
---

<section class="card">
  <h2 class="section-title">Education</h2>
  <div class="education-list">
    {
      education.map((edu) => (
        <div class="edu-entry">
          <div class="edu-header">
            <div class="edu-left">
              <h3 class="edu-institution">{edu.institution}</h3>
              <span class="edu-degree">{edu.degree}</span>
            </div>
            <div class="edu-meta">
              <span class="edu-date">{edu.date}</span>
              <span class="edu-location">{edu.location}</span>
            </div>
          </div>
          <div class="edu-details">
            <span class="edu-gpa">GPA: {edu.gpa.toFixed(1)}</span>
            {edu.honors && <span class="edu-honors">{edu.honors}</span>}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .education-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .edu-entry {
    padding-bottom: 1rem;
  }

  .edu-entry + .edu-entry {
    padding-top: 1rem;
    border-top: 1px solid var(--color-divider);
  }

  .edu-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.4rem;
  }

  .edu-left {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .edu-institution {
    font-size: 0.9375rem;
    font-weight: 600;
  }

  .edu-degree {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .edu-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.1rem;
    flex-shrink: 0;
  }

  .edu-date,
  .edu-location {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .edu-details {
    display: flex;
    gap: 1rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .edu-honors {
    color: var(--color-accent);
    font-weight: 500;
  }

  @media print {
    .edu-institution {
      font-size: 10pt;
    }
    .edu-degree,
    .edu-date,
    .edu-location,
    .edu-details {
      font-size: 9pt;
    }
  }
</style>
