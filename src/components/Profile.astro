---
import type { Profile } from "../types";

interface Props {
  profile: Profile;
}

const { profile } = Astro.props;
---

<header class="profile card">
  <h1 class="name">{profile.name}</h1>

  <ul class="contact">
    <li class="contact-item">
      <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      {profile.contact.address}
    </li>
    <li class="contact-item">
      <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      {profile.contact.phone}
    </li>
    <li class="contact-item">
      <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      <a href={`mailto:${profile.contact.email}`}>{profile.contact.email}</a>
    </li>
    <li class="contact-item">
      <svg class="icon" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      <a href={`https://${profile.contact.linkedin}`} target="_blank" rel="noopener noreferrer">{profile.contact.linkedin}</a>
    </li>
  </ul>

  <p class="summary">{profile.summary}</p>
</header>

<style>
  .profile {
    text-align: center;
    padding: 2.5rem 1.5rem;
  }

  .name {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    margin-bottom: 0.75rem;
  }

  .contact {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 1.5rem;
    margin-bottom: 1.25rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .summary {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-text);
    max-width: 680px;
    margin: 0 auto;
    text-align: left;
  }

  @media print {
    .profile {
      padding: 0 0 1rem 0;
    }

    .name {
      font-size: 18pt;
    }

    .contact {
      font-size: 9pt;
      gap: 0.25rem 1rem;
    }

    .summary {
      font-size: 10pt;
    }
  }
</style>
