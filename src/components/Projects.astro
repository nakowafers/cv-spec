---
import type { Project } from "../types";

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<section class="card">
  <h2 class="section-title">Projects</h2>
  <div class="projects">
    {
      projects.map((project) => (
        <div class="project">
          <div class="project-header">
            <h3 class="project-title">
              <a href={project.url} target="_blank" rel="noopener noreferrer">
                {project.title}
              </a>
            </h3>
            <span class="project-subtitle">{project.subtitle}</span>
          </div>
          <ul class="project-highlights">
            {project.highlights.map((h) => <li>{h}</li>)}
          </ul>
        </div>
      ))
    }
  </div>
</section>

<style>
  .project + .project {
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-divider);
  }

  .project-header {
    margin-bottom: 0.75rem;
  }

  .project-title {
    font-size: 1rem;
    font-weight: 600;
  }

  .project-title a {
    color: var(--color-text);
  }

  .project-title a::after {
    content: " ↗";
    font-size: 0.8em;
  }

  .project-subtitle {
    display: block;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-top: 0.15rem;
  }

  .project-highlights {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .project-highlights li {
    font-size: 0.875rem;
    line-height: 1.55;
    padding-left: 1rem;
    position: relative;
    color: var(--color-text);
  }

  .project-highlights li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }

  @media print {
    .project-title {
      font-size: 10pt;
    }

    .project-subtitle {
      font-size: 9pt;
    }

    .project-highlights li {
      font-size: 9pt;
    }
  }
</style>
